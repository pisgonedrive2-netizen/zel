# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server only — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Session cookie signing (min 16 chars, random string)
SESSION_SECRET=change-me-to-a-long-random-string

# One-time seed: POST /api/seed with header x-seed-secret
SEED_SECRET=change-me-for-initial-seed-only

# RapidAPI — tek anahtar; link yenileme + kişisel hesap achievement taraması
# Dashboard → uygulama anahtarı; abonelikler: youtube138, instagram-api-fast-reliable-data-scraper, tiktok-scraper7
# RAPIDAPI_KEY=your_rapidapi_key

# RapidAPI aylık limit override (yükseltilmiş plan — opsiyonel)
# RAPIDAPI_YOUTUBE_MONTHLY_LIMIT=1000
# RAPIDAPI_INSTAGRAM_MONTHLY_LIMIT=1000
# RAPIDAPI_TIKTOK_MONTHLY_LIMIT=5000

# TronGrid (kasa TRON TRC20 otomatik hareket) — https://www.trongrid.io/
TRONGRID_API_KEY=your_trongrid_api_key

# TRON cüzdan — kasa senkronu için (kasa ayarından da kaydedilebilir)
# TRON_KASA_ADDRESS=TEFigtFTbqZf47pwXPJCGdZv9jPgrgTcUE
# TRON_SYNC_FROM=2025-04-01

# İsteğe bağlı: bildirim izleme için ayrı adres (yoksa kasa adresi kullanılır)
# TRON_WATCH_ADDRESS=
# TRON_WATCH_FROM=2025-04-01
# TRON_WATCH_LABEL=Ana USDT cüzdan

# Tarayıcıda gösterilecek kasa adresi (opsiyonel — kasa ayarından da okunur)
# NEXT_PUBLIC_TRON_KASA_ADDRESS=TEFigtFTbqZf47pwXPJCGdZv9jPgrgTcUE

# Cron: POST /api/cron/refresh-links — Authorization: Bearer <secret>
# CRON_SECRET=change-me-long-random-string

# RapidAPI istek aralığı ve yeniden deneme (ms / adet)
# RAPIDAPI_MIN_REQUEST_GAP_MS=350
# RAPIDAPI_MAX_RETRIES=2
