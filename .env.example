# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server only — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Session cookie signing (min 16 chars, random string)
SESSION_SECRET=change-me-to-a-long-random-string

# One-time seed: POST /api/seed with header x-seed-secret
SEED_SECRET=change-me-for-initial-seed-only

# TronGrid (kasa TRON TRC20 otomatik hareket) — https://www.trongrid.io/
TRONGRID_API_KEY=your_trongrid_api_key

# Opsiyonel: varsayılan TRON kasa adresi (ilk kurulum)
# TRON_KASA_ADDRESS=TYourTronWalletAddress
# TRON_SYNC_FROM=2026-04-01
